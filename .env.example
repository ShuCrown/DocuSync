# DocuSync Docker — Environment Variables
# Copy to .env and adjust as needed.

# Database path (inside container)
DB_PATH=/data/db/docusync.sqlite

# File storage directory (inside container)
FILES_DIR=/data/files

# API port (default 3000)
PORT=3000

# Mail service (optional — for email bind/recovery)
# MAIL_SERVICE_URL=https://your-mail-service
# MAIL_SERVICE_KEY=your-key
